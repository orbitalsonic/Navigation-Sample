<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.NavigationSample" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary500</item>
        <item name="colorPrimaryVariant">@color/primary600</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary500</item>
        <item name="colorSecondaryVariant">@color/secondary700</item>
        <item name="colorOnSecondary">@color/white</item>
    </style>

    <style name="Theme.NavigationSample" parent="Base.Theme.NavigationSample" />

    <!--    Bottom Navigation Style-->
    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bottomNavBackground</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Active.Indicator</item>
        <item name="itemIconTint">@color/bottom_nav_icon_color</item>
        <item name="itemTextColor">@color/bottom_nav_label_color</item>
        <item name="itemTextAppearanceActive">@style/BottomNavTextAppearance</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavTextAppearance</item>
        <item name="itemRippleColor">@android:color/transparent</item>
    </style>

    <style name="Active.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary100</item>
    </style>

    <style name="BottomNavTextAppearance" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/inter_medium</item>
    </style>

    <!--    Tab Layout-->
    <style name="tabTextAppearance" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="tabTextAppearanceSelected" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- _________ Dialogs _________ -->
    <style name="DialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <style name="SingleChoiceAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorControlActivated">@color/primary500</item>
        <item name="colorControlHighlight">@color/primary50</item>
        <item name="colorAccent">@color/onSurface</item>
    </style>

    <!-- _________ ImageView _________ -->
    <style name="RoundedImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="CircularImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedCornerOverlay">
        <item name="cornerSize">4dp</item>
        <item name="cornerFamily">rounded</item>
    </style>
</resources>