<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/startup_nav_graph"
    app:startDestination="@id/startupFragment">

    <fragment
        android:id="@+id/startupFragment"
        android:name="com.orbitalsonic.navigationsample.presentation.startup.StartupFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_startup">
        <action
            android:id="@+id/action_startupFragment_to_startupLanguageFragment"
            app:destination="@id/startupLanguageFragment"
            app:popUpTo="@id/startupFragment"
            app:popUpToInclusive="true"/>
    </fragment>
    <fragment
        android:id="@+id/startupLanguageFragment"
        android:name="com.orbitalsonic.navigationsample.presentation.startup.StartupLanguageFragment"
        android:label="Language"
        tools:layout="@layout/fragment_startup_language">
    </fragment>
</navigation>